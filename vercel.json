{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run build:web",
  "framework": "vite",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/fonts/:path*",
      "destination": "https://auraone.ai/fonts/:path*"
    }
  ],
  "redirects": [
    {
      "source": "/web",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/web/",
      "destination": "/",
      "permanent": false
    }
  ]
}
