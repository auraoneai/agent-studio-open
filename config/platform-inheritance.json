{
  "$schema": "https://schemas.auraone.ai/open-studio/platform-inheritance/v1.json",
  "product": "agent-studio-open",
  "platform_version": "0.3.0",
  "inherits": {
    "tauri_template": "../desktop/src-tauri",
    "csp": "../platform/configs/platform-contracts.json#/csp_connect_src",
    "url_scheme": "auraone",
    "updater": "../platform/configs/platform-contracts.json#/updater",
    "telemetry_schema": "../platform/schemas/telemetry.schema.json",
    "telemetry_events": "../platform/schemas/telemetry-events.json",
    "crash_scrubber": "../platform/configs/sentry-scrub.json",
    "keychain_api": "../packages/platform-contracts/src/keychain.ts",
    "intake_schema": "../platform/schemas/intake-packet.schema.json",
    "intake_roles": "../platform/schemas/intake-roles.json",
    "extension_hooks": "../platform/schemas/extension-hooks.schema.json"
  },
  "browser_edition_constraints": {
    "stdio_mcp": false,
    "otlp_receiver": false,
    "allowed_mcp_transports": ["sse", "http", "websocket"]
  },
  "desktop_hooks": [
    "mcp.stdio",
    "mcp.sse",
    "mcp.http",
    "mcp.websocket",
    "otlp.http_json",
    "otlp.http_proto",
    "otlp.grpc",
    "llm_gateway.anthropic",
    "llm_gateway.openai",
    "llm_gateway.google",
    "llm_gateway.ollama",
    "intake.agent_mcp_server_metadata",
    "intake.agent_trace_card",
    "intake.agent_regression_test_suite",
    "intake.agent_otel_spans"
  ]
}
