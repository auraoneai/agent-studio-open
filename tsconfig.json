{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@auraone/platform-contracts": [
        "packages/platform-contracts/src/index.ts"
      ],
      "@auraone/aura-ide-kit": [
        "packages/aura-ide-kit/src/index.ts"
      ],
      "@auraone/proofline-oss": [
        "packages/proofline-oss/src/index.ts"
      ]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vitest/globals", "node"]
  },
  "include": ["app/src", "web/src", "vite.config.ts"],
  "references": []
}
